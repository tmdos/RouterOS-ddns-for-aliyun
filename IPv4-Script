######
# RouterOS IPv4 DDNS for Aliyun
# https://www.app.hidns.vip
######

# 阿里云AccessKeyID
:local AccessKeyID "xxxx"
# 阿里云AccessKeySecret
:local AccessKeySecret "xxxx"
# 主域名，例如baidu.com
:local DomainName "baidu.com"
# 子域名，例如home.baidu.com，只需要填写home即可
:local RR "home"
# 接口名称，例如pppoe-out1
:local wanInterface "pppoe-out1"
# 容器API地址与端口
:local apiServer "http://192.168.x.x:3000"

:local IpAddrGlobal ""

# 获取指定接口的公网IPv4地址
:local ipInfo [/ip address find interface=$wanInterface]
:if ([:len $ipInfo] > 0) do={
    :local fullIp [/ip address get ($ipInfo->0) address]
    :set IpAddrGlobal [:pick $fullIp 0 [:find $fullIp "/"]]
}

# 如果找到 IP 地址，执行更新
:if ([:len $IpAddrGlobal] > 0) do={
    :log warning ("阿里云DDNS: 准备更新 IPv4 地址 -> " . $IpAddrGlobal)
    
    :local aliddns "$apiServer/aliyun_ddns?AccessKeyID=$AccessKeyID&AccessKeySecret=$AccessKeySecret&RR=$RR&DomainName=$DomainName&IpAddr=$IpAddrGlobal&IpType=IPv4"
    
    :do {
        :local result [/tool fetch url=($aliddns) mode=http http-method=get as-value output=user]
        :if ($result->"status" = "finished") do={
            :local resData ($result->"data")
            
            :if ($resData = "loginerr") do={ :log warning "阿里云登录失败！" }
            :if ($resData = "iperr") do={ :log warning "修改解析地址信息失败！" }
            :if ($resData = "domainerr") do={ :log warning "添加新域名解析失败！" }
            :if ($resData = "same") do={ :log warning "当前配置解析地址与公网IP4相同，无需修改！" }
            
            :if ($resData = "domain") do={
                :log warning "添加新域名解析成功！"
                :log warning "增加域名信息成功！"
                :log warning "更新IP4信息成功！"
                :log warning "$IpAddrGlobal"
            }
            :if ($resData = "ip") do={
                :log warning "修改解析地址信息成功！"
                :log warning "更新IP4信息成功！"
                :log warning "$IpAddrGlobal"
            }
        }
    } on-error={
        :log warning "阿里云DDNS(IPv4): 请求失败，请检查 Docker 容器是否正常运行！"
    }
} else={
    :log warning "阿里云DDNS: 未找到 IPv4 地址，请检查接口名称！"
}
